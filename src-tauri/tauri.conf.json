{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "APK Viewer",
  "version": "0.1.0",
  "identifier": "com.cacheci.apk-info-viewer",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "APK Viewer",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "dragDropEnabled": true,
        "visible": false,
        "backgroundColor": "#181a1f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"],
    "fileAssociations": [
      {
        "ext": ["apk"],
        "name": "Android APK",
        "description": "Android application package",
        "mimeType": "application/vnd.android.package-archive",
        "role": "Viewer",
        "rank": "Default",
        "androidIntentActionFilters": ["view"]
      }
    ]
  }
}
