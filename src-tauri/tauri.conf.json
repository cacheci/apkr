{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "APK Viewer",
  "version": "0.1.0",
  "identifier": "com.cacheci.apk-info-viewer",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "APK Viewer",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"]
  }
}
